// -*- mode: jsonc -*-
{
	"layer": "top", // Waybar at top layer
	"position": "right",
	"exclusive": false,
	"height": 30, // Waybar height (to be removed for auto height)
	"spacing": 4, // Gaps between modules (4px)
	"margin-right": 4,
	"reload_style_on_change": true,
	"modules-right": [
		"hyprland/workspaces",
		"wlr/taskbar",
		"custom/separator",
		"custom/launcher",
		"cpu",
		"memory",
		"clock",
		"tray",
		"network",
		"custom/weather"
	],
	"custom/launcher": {
		"format": " ",
		"tooltip": false
	},
	"custom/separator": {
		 "format": "п’‹п’‹п’‹п’‹п’‹п’‹п’‹п’‹" ,
		 "interval": "once"
	},
	"wlr/taskbar": {
		"format": "{icon}",
		"icon-size": 24,
		"tooltip-format": "{title}",
		"orientation": "vertical",
		"on-click": "activate",
		"on-click-middle": "close"
	},
	"hyprland/workspaces": {
		"format": "{icon}",
		"on-click": "activate",
		"format-icons": {
			"1": "п„ ",
			"2": "у°іЅ",
			"3": "п„Ў",
			"4": "п†ј",
			"5": "пЃµ",
			"urgent": "пЃЄ",
			"active": "п†’",
			"default": "п„‘"
		},
		"sort-by-number": true
	},
	"tray": {
		"spacing": 10
	},
	"clock": {
		"format": "пЂ— {0:%H:%M}\nој· {0:%A}\nу°ё— {0:%d}/{0:%m}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"format-alt": "{:%Y-%m-%d}",
		"locale": "en_US.UTF-8"
	},
	"cpu": {
		"format": "{usage}% п‹›",
		"tooltip": false
	},
	"memory": {
		"format": "{percentage}% ої…\n{swapPercentage}%  у°“Ў"
	},
	"network": {
		"format": "пЂ™ {bandwidthTotalBytes}"
	},
	"custom/weather": {
		"exec": "waybar-weather",
		"restart-interval": 60,
		"return-type": "json",
		"hide-empty-text": true,
		"on-click": "pkill -USR1 waybar-weather"
	}
}
